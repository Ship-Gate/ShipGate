{
  "name": "@isl-lang/race-detector",
  "version": "1.0.0",
  "description": "Detects concurrency and race condition vulnerabilities in TypeScript/JavaScript code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "clean": "rimraf dist",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "race-condition",
    "concurrency",
    "toctou",
    "security",
    "static-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0",
    "rimraf": "^5.0.0"
  }
}
