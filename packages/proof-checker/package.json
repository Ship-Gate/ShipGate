{
  "name": "@isl-lang/proof-checker",
  "version": "1.0.0",
  "description": "Minimal, independently auditable proof bundle verifier — the trusted kernel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.10.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "vitest": "^1.2.0"
  },
  "author": "ISL Team",
  "license": "MIT",
  "sideEffects": false
}
