{
  "name": "@isl-lang/taint-tracker",
  "version": "1.0.0",
  "description": "Interprocedural taint analysis for TypeScript/JavaScript code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test:unit": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0",
    "rimraf": "^5.0.5"
  },
  "keywords": [
    "isl",
    "taint-analysis",
    "security",
    "static-analysis",
    "typescript"
  ],
  "license": "MIT",
  "sideEffects": false
}
